[sqlfluff]
dialect = postgres
templater = raw
max_line_length = 100
# LT01 (layout.spacing) and LT02 (layout.indent) produce false positives on
# PostgreSQL's implicit adjacent-string-literal concatenation, used here for
# COMMENT ON strings and multi-row INSERT VALUES. All other layout and quality
# rules remain active.
exclude_rules = LT01, LT02

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.functions]
capitalisation_policy = lower

[sqlfluff:rules:capitalisation.types]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.literals]
capitalisation_policy = upper

[sqlfluff:rules:aliasing.table]
aliasing = explicit

[sqlfluff:rules:aliasing.column]
aliasing = explicit

# Views use short aliases; full qualification is too verbose.
[sqlfluff:rules:references.qualification]
force_enable = false
