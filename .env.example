# Copy to `.env` and fill in real values. NEVER commit `.env`.
# Generate strong secrets, e.g.:  openssl rand -hex 32

# ---- PostgreSQL (the durable core) ----
POSTGRES_USER=d1
POSTGRES_PASSWORD=change_me
POSTGRES_DB=d1_database
POSTGRES_PORT=5432
POSTGRES_HOST=localhost
# Full DSN used by dbmate and psql migration targets.
DATABASE_URL=postgres://d1:change_me@localhost:5432/d1_database?sslmode=disable

# ---- Redis (job queue, Phase 4) ----
REDIS_PORT=6379

# ---- MinIO (object storage for large files) ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_too
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---- Directus (swappable adapter) ----
DIRECTUS_KEY=replace-with-random-key
DIRECTUS_SECRET=replace-with-random-secret
DIRECTUS_PORT=8055
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=change_me_admin
# Public-facing URL for link generation (used by Directus and the proxy).
DIRECTUS_PUBLIC_URL=http://localhost

# ---- Reverse proxy (Caddy, Phase 2) ----
# Port 80 routes to Directus. MinIO ports (9000/9001) are exposed directly.
PROXY_HTTP_PORT=80

# ---- Heavy-data worker (Phase 4) ----
# Token for the Operator machine user created by core/apply.sh.
WORKER_DIRECTUS_TOKEN=
# MinIO bucket for uploads (must be created via `make bootstrap-minio`).
MINIO_BUCKET=d1-files
# Worker webhook port exposed on the host.
WORKER_HTTP_PORT=8080
# Peak RAM the worker may use per job when computing streaming stats (MB).
WORKER_MEMORY_LIMIT_MB=256

# Shared secret required in the X-Worker-Secret header on all webhook POSTs.
# If left blank, webhook auth is DISABLED (dev only) — always set in production.
# The Directus Flow that calls the webhook must send this same value.
WORKER_WEBHOOK_SECRET=
# Reject presign requests larger than this many bytes (default 200 GiB).
MAX_UPLOAD_BYTES=214748364800

# ---- Analysis worker (Phase 5) ----
# Port for the FFT analysis worker webhook endpoint.
ANALYSIS_HTTP_PORT=8081

# ---- Text-to-SQL + local LLM (Phase 6, "llm" compose profile) ----
# Start with: docker compose --profile llm up -d
# Host port for the text-to-SQL API.
LLM_HTTP_PORT=8082
# Ollama runtime port (host side).
OLLAMA_PORT=11434
# Models served by Ollama (pull them once after first start — see the runbook).
OLLAMA_SQL_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text
# Per-query statement timeout enforced by the plugin (milliseconds).
LLM_STATEMENT_TIMEOUT_MS=5000
# Read-only DSN: a LOGIN role that inherits d1_llm_readonly. Create it once after
# migrations (see docs/runbooks/text-to-sql.md). NEVER point this at the
# superuser. Host is `postgres` inside the compose network.
LLM_DATABASE_URL=postgres://d1_llm_app:change_me_llm@postgres:5432/d1_database?sslmode=disable
# Writer DSN used ONLY by the embedding backfill (writes semantic_embeddings).
EMBED_DATABASE_URL=postgres://d1:change_me@postgres:5432/d1_database?sslmode=disable
